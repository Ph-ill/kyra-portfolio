---
import { siteConfig } from "../config";
---

<section
  class="section-shell pt-6 md:pt-10"
  aria-labelledby="pov-heading"
>
  <div class="section-grid">
    <div class="col-span-12 lg:col-span-10 lg:col-start-2">
      <p
        id="pov-heading"
        class="font-display text-3xl leading-tight text-[var(--color-text)] sm:text-4xl md:text-5xl lg:text-6xl"
      >
        {siteConfig.pov}
      </p>
    </div>
  </div>
</section>

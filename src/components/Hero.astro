---
import { siteConfig } from "../config";
---

<section id="hero" class="hero-shell" aria-labelledby="hero-heading">
  <div class="hero-orb hero-orb-left" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-right" aria-hidden="true"></div>
  <div class="mx-auto grid min-h-[100svh] max-w-7xl items-center gap-10 px-6 pb-12 pt-24 lg:grid-cols-12 lg:px-10 lg:pb-12 lg:pt-24">
    <div class="lg:col-span-7">
      <p class="section-kicker mb-6">{siteConfig.hero.eyebrow}</p>
      <h1 id="hero-heading" class="font-display text-6xl leading-none text-[var(--color-text)] sm:text-7xl md:text-8xl lg:text-[8.5rem]">
        {siteConfig.name}
      </h1>
      <p class="mt-6 max-w-2xl text-xl leading-8 text-[var(--color-soft)] md:text-2xl">
        {siteConfig.hero.statement}
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href={siteConfig.hero.primaryCta.href} class="button-primary">
          {siteConfig.hero.primaryCta.label}
        </a>
        <a href={siteConfig.hero.secondaryCta.href} class="button-secondary">
          {siteConfig.hero.secondaryCta.label}
        </a>
      </div>
    </div>
    <div class="lg:col-span-5">
      <aside class="hero-card">
        <div class="space-y-6">
          <div class="overflow-hidden rounded-[1.25rem] border border-white/10 bg-black/20">
            <img
              src="/headshot.jpeg"
              alt="Professional headshot of Kyra Scargill."
              class="aspect-[4/5] w-full object-cover"
              loading="eager"
              width="960"
              height="1200"
            />
          </div>
          <div>
            <p class="text-sm uppercase tracking-[0.24em] text-[var(--color-muted)]">
              Selected credentials
            </p>
            <ul class="mt-4 space-y-3 text-base leading-7 text-[var(--color-soft)]">
              {siteConfig.hero.highlights.map((highlight) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 inline-block h-2 w-2 rounded-full bg-[var(--color-accent)]" aria-hidden="true"></span>
                  <span>{highlight}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="border-t border-white/10 pt-6">
            <p class="text-sm uppercase tracking-[0.24em] text-[var(--color-muted)]">
              Clients
            </p>
            <p class="mt-4 font-display text-3xl leading-tight text-[var(--color-text)]">
              Google, Netflix, Snap, Spotify, LA28, Amazon-adjacent scale problems.
            </p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

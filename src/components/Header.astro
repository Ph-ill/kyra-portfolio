---
import { siteConfig } from "../config";

const navItems = [
  { label: "What I Do", href: "#what-i-do" },
  { label: "Clients", href: "#clients" },
  { label: "Case Studies", href: "#case-studies" },
  { label: "About", href: "#about" },
  { label: "Contact", href: "#contact" },
];
---

<header id="header" class="site-header" role="banner">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-10" aria-label="Primary navigation">
    <a href="#hero" class="font-display text-2xl text-[var(--color-text)]">
      {siteConfig.name}
    </a>
    <div class="hidden items-center gap-6 md:flex">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link">
          {item.label}
        </a>
      ))}
    </div>
    <a
      href="/resume.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="button-secondary hidden md:inline-flex"
    >
      Resume
    </a>
  </nav>
</header>

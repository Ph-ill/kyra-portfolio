---
const { heading, kicker, items, id } = Astro.props;
---

<section id={id} class="section-shell" aria-labelledby={`${id}-heading`}>
  <div class="section-grid gap-y-8">
    <div class="col-span-12 lg:col-span-4">
      <p class="section-kicker">{kicker}</p>
      <h2 id={`${id}-heading`} class="section-heading">
        {heading}
      </h2>
    </div>
    <div class="col-span-12 grid gap-5 lg:col-span-8">
      {items.map((item) => (
        <figure class="panel space-y-6">
          <blockquote class="font-display text-2xl leading-tight text-[var(--color-text)] md:text-4xl">
            “{item.quote}”
          </blockquote>
          <figcaption class="flex items-center gap-4">
            <div class="testimonial-avatar" aria-hidden="true">{item.initials}</div>
            <div class="space-y-1">
              <a
                href={item.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="text-base font-semibold text-[var(--color-text)] transition-colors hover:text-[var(--color-accent)]"
              >
                {item.name}
              </a>
              <p class="text-sm leading-6 text-[var(--color-soft)]">
                {item.title}, {item.company}
              </p>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
